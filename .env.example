# =========================================================
# Appier AI Deal Room — Environment Variables
# Copy this file to .env.local and fill in your values
# =========================================================

# -----------------------------------------------------------
# NextAuth.js v5 (required for Google OAuth)
# Generate with: openssl rand -base64 32
# -----------------------------------------------------------
AUTH_SECRET=

# -----------------------------------------------------------
# Google OAuth 2.0
# Create credentials at: https://console.cloud.google.com/
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# -----------------------------------------------------------
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# -----------------------------------------------------------
# Gemini API (optional — mock analysis used when not set)
# Get key at: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------
GEMINI_API_KEY=

# -----------------------------------------------------------
# Database (Google Cloud SQL / PostgreSQL)
# -----------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/dbname

# -----------------------------------------------------------
# Google Drive (for meeting file storage)
# -----------------------------------------------------------
GOOGLE_DRIVE_FOLDER_ID=

# -----------------------------------------------------------
# App URL (set to your production domain on Vercel)
# -----------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
